# --- IDE / OS noise ---
.idea/
.vscode/
*.iml
.DS_Store

# --- Gradle build cache & outputs ---
.gradle/
**/build/
out/

# --- Kotlin compiler caches ---
.kotlin/

# --- Local-only Gradle configuration ---
# Contains absolute paths and signing creds; never commit.
local.properties

# --- Compiled / bundled artifacts ---
*.class
*.jar
*.war
*.nar
*.ear
*.aar
*.apk
*.dex
*.zip
*.tar.gz
*.rar

# Gradle wrapper jar bootstraps `./gradlew` on fresh clones; commit it.
!gradle/wrapper/gradle-wrapper.jar

# --- Native iOS build outputs ---
*.xcframework/
*.framework/
DerivedData/

# --- JVM crash logs ---
hs_err_pid*
replay_pid*

# --- Misc Java tooling ---
*.log
*.ctxt
.mtj.tmp/

# --- Generated test resources ---
# Mirror of gplayer/src/commonTest/resources/, populated by the
# syncOmnifretAndroidTestResources Gradle task so AGP's unit-test
# resource pipeline picks up the binary fixtures.
gplayer/src/androidUnitTest/resources/
